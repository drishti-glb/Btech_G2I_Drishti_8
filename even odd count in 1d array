#include<stdio.h>
int main()
{
    int i, n, a[n], even=0, odd=0;
    printf("Enter the size of the array:\t");
    scanf("%d",&n);
    
    printf("Enter the elements of the array:\n");
    for(i=0;i<n;i++)
    {
        scanf("%d", &a[i]);
    }
    for(i=0;i<n;i++)
    {
        if(a[i]%2==0)
        {
            even++;
        }
        else
        {
            odd++;
        }
    }
    printf("The even digits are: %d\n",even);
    printf("The odd digits are: %d\n",odd);
    return 0;
}
