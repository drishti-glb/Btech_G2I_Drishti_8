#include <stdio.h>

int main()
{
    int n, i, j, sum = 0;

    printf("Enter order of matrix (n): ");
    scanf("%d", &n);

    int a[n][n];

    printf("Enter elements of matrix:\n");
    for (i = 0; i < n; i++)
        for (j = 0; j < n; j++)
            scanf("%d", &a[i][j]);

    // Print matrix
    printf("\nMatrix:\n");
    for (i = 0; i < n; i++)
    {
        for (j = 0; j < n; j++)
            printf("%4d", a[i][j]);
        printf("\n");
    }

    // Sum of diagonal elements
    for (i = 0; i < n; i++)
        sum = sum + a[i][i];

    printf("\nSum of diagonal elements = %d\n", sum);

    return 0;
}